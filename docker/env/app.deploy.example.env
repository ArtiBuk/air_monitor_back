DJANGO_ENV=production
DJANGO_DEBUG=0
DJANGO_SECRET_KEY=change-me-production-secret
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,air-monitor-web
CSRF_TRUSTED_ORIGINS=http://localhost,http://127.0.0.1
DJANGO_TIME_ZONE=Asia/Krasnoyarsk
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=change-me-admin-password
DJANGO_SUPERUSER_FIRST_NAME=Admin
DJANGO_SUPERUSER_LAST_NAME=User

PORT=8000
APP_PORT=8000
GUNICORN_WORKERS=2
GUNICORN_TIMEOUT=120
GUNICORN_RELOAD=0

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
CELERY_LOG_LEVEL=INFO
CELERY_WORKER_NAME=worker@%h
CELERY_HEALTHCHECK_NODE=worker@air-monitor-worker
CELERY_WORKER_QUEUES=default,monitoring,ml
CELERY_TASK_SOFT_TIME_LIMIT=900
CELERY_TASK_TIME_LIMIT=1200
CELERY_WORKER_MAX_TASKS_PER_CHILD=100
CELERY_VISIBILITY_TIMEOUT=3600
CELERY_BEAT_SCHEDULE_FILENAME=/app/run/celerybeat-schedule

JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_MINUTES=30
JWT_REFRESH_TTL_DAYS=14
JWT_ISSUER=air-monitor-back
JWT_ACCESS_COOKIE_NAME=access_token
JWT_REFRESH_COOKIE_NAME=refresh_token
JWT_COOKIE_HTTPONLY=1
JWT_COOKIE_SECURE=0
JWT_COOKIE_SAMESITE=Lax
JWT_ACCESS_COOKIE_PATH=/
JWT_REFRESH_COOKIE_PATH=/api/auth/

SESSION_COOKIE_SECURE=0
CSRF_COOKIE_SECURE=0
SECURE_HSTS_SECONDS=0

MONITORING_INTERVAL=Interval1H
MONITORING_WINDOW_HOURS=1
MONITORING_COLLECTION_LOOKBACK_HOURS=48
MONITORING_FORECAST_HORIZON_HOURS=24
MONITORING_INPUT_WINDOW_HOURS=72

MYCITYAIR_TOKEN=change-me

DJANGO_LOG_LEVEL=INFO
API_LOG_LEVEL=INFO
AUTH_LOG_LEVEL=INFO
MONITORING_LOG_LEVEL=INFO
CELERY_TRACE_LOG_LEVEL=INFO
DJANGO_DB_LOG_LEVEL=WARNING
